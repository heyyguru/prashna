modules = ["php-8.4"]
[nix]
channel = "stable-25_05"
packages = ["unzip"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "PHP Server"

[[workflows.workflow]]
name = "PHP Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "php -S 0.0.0.0:5000 -t Prashna2zip/Guru-Assistantzip-2zipzip/Guru-Assistantzip-2zip/ Prashna2zip/Guru-Assistantzip-2zipzip/Guru-Assistantzip-2zip/router.php"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
